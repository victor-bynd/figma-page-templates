rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------------
    // Helper: verify the requesting user belongs to the given org.
    // We look up the user's own document (written on sign-in) to get orgId.
    // -----------------------------------------------------------------------
    function belongsToOrg(orgId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return request.auth != null
          && userDoc != null
          && userDoc.data.orgId == orgId;
    }

    // -----------------------------------------------------------------------
    // Org documents — orgs/{orgId}
    // -----------------------------------------------------------------------
    match /orgs/{orgId} {
      allow read, write: if belongsToOrg(orgId);
    }

    // -----------------------------------------------------------------------
    // Templates — orgs/{orgId}/templates/{templateId}
    // -----------------------------------------------------------------------
    match /orgs/{orgId}/templates/{templateId} {
      // Any member of the org can read templates.
      allow read: if belongsToOrg(orgId);

      // Any member can create a template.
      allow create: if belongsToOrg(orgId)
                    && request.resource.data.createdBy == request.auth.uid;

      // Any member can update (e.g. rename), but not change createdBy.
      allow update: if belongsToOrg(orgId)
                    && request.resource.data.createdBy == resource.data.createdBy;

      // Only the creator can delete their own template.
      allow delete: if belongsToOrg(orgId)
                    && resource.data.createdBy == request.auth.uid;
    }

    // -----------------------------------------------------------------------
    // User documents — users/{userId}
    // -----------------------------------------------------------------------
    match /users/{userId} {
      // Users can only read and write their own document.
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // -----------------------------------------------------------------------
    // Deny everything else by default.
    // -----------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
