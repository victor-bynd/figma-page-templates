rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------------
    // Helper: verify the requesting user belongs to the given org.
    // Reads orgId from the custom claim set by the Cloud Function.
    // -----------------------------------------------------------------------
    function belongsToOrg(orgId) {
      return request.auth != null && request.auth.token.orgId == orgId;
    }

    // -----------------------------------------------------------------------
    // Org documents — orgs/{orgId}
    // -----------------------------------------------------------------------
    match /orgs/{orgId} {
      allow read, write: if belongsToOrg(orgId);
    }

    // -----------------------------------------------------------------------
    // Templates — orgs/{orgId}/templates/{templateId}
    // -----------------------------------------------------------------------
    match /orgs/{orgId}/templates/{templateId} {
      // Any member of the org can read templates.
      allow read: if belongsToOrg(orgId);

      // Any member can create a template.
      allow create: if belongsToOrg(orgId)
                    && request.resource.data.createdBy == request.auth.uid;

      // Any member can update (e.g. rename), but not change createdBy.
      allow update: if belongsToOrg(orgId)
                    && request.resource.data.createdBy == resource.data.createdBy;

      // Only the creator can delete their own template.
      allow delete: if belongsToOrg(orgId)
                    && resource.data.createdBy == request.auth.uid;
    }

    // -----------------------------------------------------------------------
    // Groups — orgs/{orgId}/groups/{groupId}
    // -----------------------------------------------------------------------
    match /orgs/{orgId}/groups/{groupId} {
      // Any member of the org can read groups.
      allow read: if belongsToOrg(orgId);

      // Any member can create a group.
      allow create: if belongsToOrg(orgId)
                    && request.resource.data.createdBy == request.auth.uid;

      // Any member can update (e.g. rename, reorder).
      allow update: if belongsToOrg(orgId)
                    && request.resource.data.createdBy == resource.data.createdBy;

      // Any member can delete a group.
      allow delete: if belongsToOrg(orgId);
    }

    // -----------------------------------------------------------------------
    // User documents — users/{userId}
    // Only the user can read/write their own doc, and orgId is forbidden
    // in client writes (it's set server-side via custom claims).
    // -----------------------------------------------------------------------
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
                    && !('orgId' in request.resource.data);
      allow update: if request.auth != null && request.auth.uid == userId
                    && !('orgId' in request.resource.data);
    }

    // -----------------------------------------------------------------------
    // Deny everything else by default.
    // -----------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
